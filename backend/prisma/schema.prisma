generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(uuid())
  name          String
  email         String             @unique
  passwordHash  String
  phone         String?
  flatNo        String?
  wing          String?
  role          Role               @default(RESIDENT)
  createdAt     DateTime           @default(now())
  statusChanges ComplaintHistory[] @relation("StatusChangedBy")
  complaints    Complaint[]        @relation("ResidentComplaints")
  noticesPosted Notice[]           @relation("NoticePostedBy")
  notifications Notification[]     @relation("UserNotifications")

  @@map("users")
}

model Complaint {
  id          String             @id @default(uuid())
  residentId  String
  description String
  status      ComplaintStatus    @default(OPEN)
  priority    Priority           @default(LOW)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  category    ComplaintCategory
  history     ComplaintHistory[]
  media       ComplaintMedia[]
  resident    User               @relation("ResidentComplaints", fields: [residentId], references: [id])

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("complaints")
}

model ComplaintMedia {
  id          String    @id @default(uuid())
  complaintId String
  url         String
  type        String    @default("image")
  uploadedAt  DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@map("complaint_media")
}

model ComplaintHistory {
  id          String           @id @default(uuid())
  complaintId String
  oldStatus   ComplaintStatus?
  newStatus   ComplaintStatus
  changedBy   String
  note        String?
  createdAt   DateTime         @default(now())
  actor       User             @relation("StatusChangedBy", fields: [changedBy], references: [id])
  complaint   Complaint        @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@map("complaint_history")
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  body        String
  isImportant Boolean  @default(false)
  postedBy    String
  createdAt   DateTime @default(now())
  poster      User     @relation("NoticePostedBy", fields: [postedBy], references: [id])

  @@map("notices")
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

enum Role {
  RESIDENT
  ADMIN
}

enum ComplaintCategory {
  ELECTRICAL
  PLUMBING
  CLEANING
  SECURITY
  PARKING
  STRUCTURAL
  OTHER
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}
