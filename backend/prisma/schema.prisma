generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  RESIDENT
  ADMIN
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(RESIDENT)
  createdAt    DateTime @default(now())

  complaints    Complaint[]        @relation("ResidentComplaints")
  statusChanges ComplaintHistory[] @relation("StatusChangedBy")
  noticesPosted Notice[]           @relation("NoticePostedBy")

  @@map("users")
}

model Complaint {
  id          String          @id @default(uuid())
  residentId  String
  category    String
  description String
  status      ComplaintStatus @default(OPEN)
  priority    Priority        @default(LOW)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  resident User               @relation("ResidentComplaints", fields: [residentId], references: [id])
  media    ComplaintMedia[]
  history  ComplaintHistory[]

  @@map("complaints")
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model ComplaintMedia {
  id          String   @id @default(uuid())
  complaintId String
  url         String
  type        String   @default("image")
  uploadedAt  DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@map("complaint_media")
}

model ComplaintHistory {
  id          String           @id @default(uuid())
  complaintId String
  oldStatus   ComplaintStatus?
  newStatus   ComplaintStatus
  changedBy   String
  note        String?
  createdAt   DateTime         @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  actor     User      @relation("StatusChangedBy", fields: [changedBy], references: [id])

  @@map("complaint_history")
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  body        String
  isImportant Boolean  @default(false)
  postedBy    String
  createdAt   DateTime @default(now())

  poster User @relation("NoticePostedBy", fields: [postedBy], references: [id])

  @@map("notices")
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}